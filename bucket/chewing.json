{
    "version": "26.4.2.0",
    "description": "新酷音輸入法 (New Chewing) for Windows",
    "homepage": "https://chewing.im/",
    "license": "GPL-2.0-only",
    "url": "https://codeberg.org/chewing/windows-chewing-tsf/releases/download/v26.4.2.0/windows-chewing-tsf-26.4.2.0-installer.msi",
    "hash": "e29fd7153c15e44108a0a076cef7d9e3c6bd15e631bf488d760a166352997fd3",
    "installer": {
        "keep": true,
        "script": "msiexec /i \"$dir\\windows-chewing-tsf-26.4.2.0-installer.msi\" /qn /norestart"
    },
    "uninstaller": {
        "script": "msiexec /x \"$dir\\windows-chewing-tsf-26.4.2.0-installer.msi\" /qn /norestart"
    },
    "post_install": [
        "$model = (Get-WmiObject -Class Win32_ComputerSystem).Model",
        "$vendor = (Get-WmiObject -Class Win32_ComputerSystem).Manufacturer",
        "$isVM = $model -match 'Virtual|VMware|Hyper-V' -or $vendor -match 'VirtualBox|VMware|Microsoft Corporation'",
        "$chewingPath = \"$env:APPDATA\\Chewing\"",
        "",
        "if ($isVM) {",
        "    Write-Host '偵測到 VM 環境，正在連結至共享資料夾...' -ForegroundColor Cyan",
        "    $sharedPath = \"Z:\\Config\\Chewing\" # 請確保 VM 中 Z 槽已掛載",
        "    if (Test-Path $chewingPath) { Remove-Item $chewingPath -Recurse -Force }",
        "    New-Item -ItemType SymbolicLink -Path $chewingPath -Target $sharedPath -Force",
        "} else {",
        "    Write-Host '偵測到 Host 環境，正在建立同步連結...' -ForegroundColor Green",
        "    $hostSyncPath = \"C:\\Sync\\Chewing\" # <--- Jack，請修改為你 Host 上的實際同步路徑",
        "    if (!(Test-Path $hostSyncPath)) { New-Item -ItemType Directory -Path $hostSyncPath -Force }",
        "    if (Test-Path $chewingPath) {",
        "        if (!((Get-Item $chewingPath).Attributes -match 'ReparsePoint')) {",
        "            Copy-Item \"$chewingPath\\*\" $hostSyncPath -Recurse -Force",
        "            Remove-Item $chewingPath -Recurse -Force",
        "        }",
        "    }",
        "    New-Item -ItemType SymbolicLink -Path $chewingPath -Target $hostSyncPath -Force",
        "}"
    ],
    "checkver": {
        "url": "https://codeberg.org/chewing/windows-chewing-tsf/releases",
        "regex": "v([\\d.]+)/windows-chewing-tsf-([\\d.]+)-installer\\.msi"
    },
    "autoupdate": {
        "url": "https://codeberg.org/chewing/windows-chewing-tsf/releases/download/v$version/windows-chewing-tsf-$version-installer.msi"
    }
}